# Antidote+ backend — copy this file to `.env` and fill in real values.
# The Gemini API key is read ONLY here, server-side. It is never sent to,
# embedded in, or reachable from the frontend.

# Your Google Gemini API key (leave blank to run in safe-fallback mode).
GEMINI_API_KEY=

# Gemini model used for both vision (snake ID) and text (summary).
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated origins allowed by CORS (the Vite dev server).
ALLOWED_ORIGINS=http://localhost:5173

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Below this confidence the identifier refuses to name a species and returns
# the safe default (assume venomous).
LOW_CONFIDENCE=0.6
